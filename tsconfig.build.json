{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,

		"declaration": true,
		"declarationMap": false,
		"emitDeclarationOnly": true,

		"rootDir": "./src",
		"outDir": "./dist"
	},
	"include": ["src/index.ts", "src/hooks/**/*"],
	"exclude": ["node_modules", "dist", "src/main.tsx", "src/App.tsx", "**/*.test.ts", "**/*.spec.ts"]
}
