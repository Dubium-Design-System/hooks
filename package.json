{
	"name": "@dubium/hooks",
	"private": false,
	"version": "0.0.7",
	"type": "module",
	"homepage": "https://dubium-design-system.github.io/hooks/",
	"bugs": {
		"url": "https://github.com/Dubium-Design-System/hooks/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Dubium-Design-System/hooks.git"
	},
	"description": "A lightweight React hooks library for Dubium Design System.",
	"keywords": [
		"react",
		"hooks",
		"design-system",
		"library",
		"frontend"
	],
	"author": "https://github.com/DubiumEkb",
	"license": "MIT",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"clean": "rimraf dist",
		"typecheck": "tsc --noEmit",
		"build:types": "tsc -p tsconfig.build.json",
		"build": "npm run clean && vite build && npm run build:types",
		"prepack": "npm run clean && npm run build && npm run lint",
		"pack:check": "npm pack --dry-run",
		"pack:local": "npm pack",
		"format": "prettier --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:inspect": "npm run build && eslint --inspect-config",
		"version:alpha": "npm version prerelease --preid=alpha",
		"version:beta": "npm version prerelease --preid=beta",
		"version:patch": "npm version patch",
		"version:minor": "npm version minor",
		"version:major": "npm version major",
		"version:major:alpha": "npm version premajor --preid=alpha",
		"version:major:beta": "npm version premajor --preid=beta",
		"publish:alpha": "npm publish --access=public --tag alpha",
		"publish:beta": "npm publish --access=public --tag beta",
		"publish:next": "npm publish --access=public --tag next",
		"publish:release": "npm publish --access=public --tag latest",
		"release:alpha": "npm run version:alpha && npm run publish:alpha",
		"release:beta": "npm run version:beta && npm run publish:beta",
		"release:patch": "npm run version:patch && npm run publish:release",
		"release:minor": "npm run version:minor && npm run publish:release",
		"release:major": "npm run version:major && npm run publish:release",
		"release:major:alpha": "npm run version:major:alpha && npm run publish:alpha",
		"release:major:beta": "npm run version:major:beta && npm run publish:beta"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@dubium/eslint-config": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"globals": "^17.7.0",
		"prettier": "^3.9.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rimraf": "^6.1.3",
		"rollup-plugin-visualizer": "^7.0.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.4"
	}
}
